# =============================================================================
# AlphaScan Pro — 本機設定（複製為 .env 後填入）
# 複製指令（專案根目錄）:  copy .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# 永豐金 Shioaji API（Token 登入）
# 申請與管理: https://www.sinotrade.com.tw/newweb/PythonAPIKey/
# Secret 僅建立時顯示一次，請自行安全保存。
# -----------------------------------------------------------------------------
SINOPAC_API_KEY=
SINOPAC_SECRET_KEY=

# 下單或部分情境需憑證（選填；若只做行情訂閱可先留空，依實際錯誤訊息再補）
# Windows 範例: C:\Users\你的帳號\Downloads\sinopac.pfx
# SINOPAC_CA_PATH=
# SINOPAC_CA_PASSWORD=

# 是否使用模擬環境（依 Shioaji 文件與帳戶類型；true / false）
SINOPAC_SIMULATION=false

# -----------------------------------------------------------------------------
# Discord Webhook 通知設定
# 建立 Webhook: Discord 頻道設定 → 整合 → Webhook → 複製連結
# 每種策略可設不同頻道，也可以共用同一個 URL。
# -----------------------------------------------------------------------------

# 多方選股（long-selection）掃描完成後推送的 Webhook URL
DISCORD_WEBHOOK_LONG=

# 空方選股（short-selection）掃描完成後推送的 Webhook URL
DISCORD_WEBHOOK_SHORT=

# 自選清單（watchlist）開收盤或條件觸發時推送的 Webhook URL
DISCORD_WEBHOOK_WATCHLIST=

# 盤中掃描排程完成後是否自動推送 Discord 通知（true / false，預設 false）
# 設為 true 後，每 30 分鐘的盤中掃描若有結果會自動發送
DISCORD_NOTIFY_ON_SCAN=false

# 每則 Discord 訊息最多顯示幾檔股票（預設 10，上限建議 ≤ 25）
DISCORD_MAX_STOCKS=10
