# =============================================================================
# AlphaScan Pro — 本機設定範本
# 複製為 .env 後填入： copy .env.example .env
#
# 連結／密鑰貼哪？
#   永豐 Key / Secret     → SINOPAC_API_KEY、SINOPAC_SECRET_KEY
#   Discord 多方 Webhook  → DISCORD_WEBHOOK_LONG（整條 https://discord.com/api/webhooks/...）
#   Discord 空方 Webhook  → DISCORD_WEBHOOK_SHORT
#   Discord 自選 Webhook  → DISCORD_WEBHOOK_WATCHLIST
#   Gemini                → GEMINI_API_KEY
# =============================================================================

# =============================================================================
# 永豐金 Shioaji API
# https://www.sinotrade.com.tw/newweb/PythonAPIKey/
# =============================================================================
SINOPAC_API_KEY=
SINOPAC_SECRET_KEY=
# SINOPAC_CA_PATH=
# SINOPAC_CA_PASSWORD=
SINOPAC_SIMULATION=false

# =============================================================================
# Discord Webhook（整條 URL 貼在等號後）
# 頻道 → 編輯頻道 → 整合功能 → Webhooks → 複製 Webhook URL
# =============================================================================
DISCORD_WEBHOOK_LONG=
DISCORD_WEBHOOK_SHORT=
DISCORD_WEBHOOK_WATCHLIST=
DISCORD_NOTIFY_ON_SCAN=false
DISCORD_NOTIFY_ONLY_NEW_TRIGGERS=true
DISCORD_MAX_STOCKS=10

# =============================================================================
# Google Gemini（選填）
# =============================================================================
# GEMINI_API_KEY=
# GEMINI_MODEL_ID=gemini-1.5-flash

# =============================================================================
# 前端（選填）
# =============================================================================
# VITE_API_BASE=http://127.0.0.1:8000

# =============================================================================
# 雙刀戰法：綜合評分權重（可選，預設即下列數值）
# 用途：composite_score = crossings * 50% + half-life * 35% + pearson * 15%
# 說明：三者建議總和為 1.0；若不是 1.0，後端會自動正規化。
# =============================================================================
CORR_WEIGHT_CROSSINGS=0.50
CORR_WEIGHT_HALFLIFE=0.35
CORR_WEIGHT_PEARSON=0.15
